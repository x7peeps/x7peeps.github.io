[
{{- range $index, $page := site.RegularPages.ByLastmod.Reverse -}}
  {{- if $index }},{{ end }}
  {{- $tags := slice -}}
  {{- range ($page.Params.tags | default (slice)) -}}
    {{- $tags = $tags | append (printf "%v" .) -}}
  {{- end -}}
  {{- dict
    "title" $page.Title
    "url" $page.RelPermalink
    "section" $page.Section
    "summary" ($page.Plain | htmlUnescape | truncate 150)
    "tags" $tags
    "updated" ($page.Lastmod.Format "2006-01-02T15:04:05Z07:00")
    | jsonify -}}
{{- end }}
]
