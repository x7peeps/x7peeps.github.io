{{- $nodes := slice -}}
{{- range site.Sections.ByWeight -}}
  {{- if ne .Section "关于" -}}
    {{- $pages := partial "x7/knowledge-pages.html" . -}}
    {{- $nodes = $nodes | append (dict
      "id" (printf "domain-%s" (.Section | urlize))
      "title" .Title
      "url" .RelPermalink
      "count" (len $pages)
    ) -}}
  {{- end -}}
{{- end -}}
{{- return $nodes -}}
