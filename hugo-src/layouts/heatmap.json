{{- $allPages := where site.RegularPages "Type" "ne" "home" -}}
{{- $now := now -}}
{{- $start := $now.AddDate -1 0 0 -}}
{{- $dateMap := dict -}}
{{- range $allPages -}}
  {{- $d := .Date.Format "2006-01-02" -}}
  {{- $count := 0 -}}
  {{- if isset $dateMap $d -}}
    {{- $count = index $dateMap $d -}}
  {{- end -}}
  {{- $dateMap = merge $dateMap (dict $d (add $count 1)) -}}
{{- end -}}
{{- $days := slice -}}
{{- $cur := $start -}}
{{- range $i := seq 371 -}}
  {{- $d := $cur.Format "2006-01-02" -}}
  {{- $count := 0 -}}
  {{- if isset $dateMap $d -}}
    {{- $count = index $dateMap $d -}}
  {{- end -}}
  {{- $days = $days | append (dict "date" $d "count" $count) -}}
  {{- $cur = $cur.AddDate 0 0 1 -}}
{{- end -}}
{"days":{{ $days | jsonify }}}
